<?xml version="1.0"?>
<Ontology xmlns="http://www.w3.org/2002/07/owl#"
     xml:base="http://www.okkam.it/maestro"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     ontologyIRI="http://www.okkam.it/maestro">
    <Prefix name="" IRI="http://www.okkam.it/maestro/"/>
    <Prefix name="owl" IRI="http://www.w3.org/2002/07/owl#"/>
    <Prefix name="rdf" IRI="http://www.w3.org/1999/02/22-rdf-syntax-ns#"/>
    <Prefix name="xml" IRI="http://www.w3.org/XML/1998/namespace"/>
    <Prefix name="xsd" IRI="http://www.w3.org/2001/XMLSchema#"/>
    <Prefix name="rdfs" IRI="http://www.w3.org/2000/01/rdf-schema#"/>

    <Declaration><Class IRI="/Anatomical_Part"/></Declaration>
    <Declaration><Class IRI="/Disease"/></Declaration>
    <Declaration><Class IRI="/Drug"/></Declaration>
    <Declaration><Class IRI="/Person"/></Declaration>
    <Declaration><Class IRI="/Symptom"/></Declaration>

    <Declaration><ObjectProperty IRI="/affects"/></Declaration>
    <Declaration><ObjectProperty IRI="/causes"/></Declaration>
    <Declaration><ObjectProperty IRI="/experiences"/></Declaration>
    <Declaration><ObjectProperty IRI="/has_anatomical_part"/></Declaration>
    <Declaration><ObjectProperty IRI="/has_symptom"/></Declaration>
    <Declaration><ObjectProperty IRI="/indicates"/></Declaration>
    <Declaration><ObjectProperty IRI="/is_treated_by"/></Declaration>
    <Declaration><ObjectProperty IRI="/located_in"/></Declaration>
    <Declaration><ObjectProperty IRI="/side_effect_of"/></Declaration>
    <Declaration><ObjectProperty IRI="/targets"/></Declaration>
    <Declaration><ObjectProperty IRI="/treats"/></Declaration>

    <Declaration><DataProperty IRI="/name"/></Declaration>
    <Declaration><DataProperty IRI="/age"/></Declaration>
    <Declaration><DataProperty IRI="/dosage"/></Declaration>
    <Declaration><DataProperty IRI="/active_ingredient"/></Declaration>
    <Declaration><DataProperty IRI="/severity"/></Declaration>

    <SubObjectPropertyOf>
        <ObjectProperty IRI="/has_symptom"/>
        <ObjectProperty abbreviatedIRI="owl:topObjectProperty"/>
    </SubObjectPropertyOf>
    <SubObjectPropertyOf>
        <ObjectProperty IRI="/is_treated_by"/>
        <ObjectProperty abbreviatedIRI="owl:topObjectProperty"/>
    </SubObjectPropertyOf>
    <SubObjectPropertyOf>
        <ObjectProperty IRI="/targets"/>
        <ObjectProperty abbreviatedIRI="owl:topObjectProperty"/>
    </SubObjectPropertyOf>
    <SubObjectPropertyOf>
        <ObjectProperty IRI="/treats"/>
        <ObjectProperty abbreviatedIRI="owl:topObjectProperty"/>
    </SubObjectPropertyOf>

    <InverseObjectProperties>
        <ObjectProperty IRI="/causes"/>
        <ObjectProperty IRI="/side_effect_of"/>
    </InverseObjectProperties>
    <InverseObjectProperties>
        <ObjectProperty IRI="/is_treated_by"/>
        <ObjectProperty IRI="/treats"/>
    </InverseObjectProperties>

    <ObjectPropertyDomain><ObjectProperty IRI="/affects"/><Class IRI="/Disease"/></ObjectPropertyDomain>
    <ObjectPropertyDomain><ObjectProperty IRI="/causes"/><Class IRI="/Drug"/></ObjectPropertyDomain>
    <ObjectPropertyDomain><ObjectProperty IRI="/experiences"/><Class IRI="/Person"/></ObjectPropertyDomain>
    <ObjectPropertyDomain><ObjectProperty IRI="/has_anatomical_part"/><Class IRI="/Person"/></ObjectPropertyDomain>
    <ObjectPropertyDomain><ObjectProperty IRI="/has_symptom"/><Class IRI="/Disease"/></ObjectPropertyDomain>
    <ObjectPropertyDomain><ObjectProperty IRI="/indicates"/><Class IRI="/Symptom"/></ObjectPropertyDomain>
    <ObjectPropertyDomain><ObjectProperty IRI="/is_treated_by"/><Class IRI="/Disease"/></ObjectPropertyDomain>
    <ObjectPropertyDomain><ObjectProperty IRI="/located_in"/><Class IRI="/Symptom"/></ObjectPropertyDomain>
    <ObjectPropertyDomain><ObjectProperty IRI="/side_effect_of"/><Class IRI="/Symptom"/></ObjectPropertyDomain>
    <ObjectPropertyDomain><ObjectProperty IRI="/targets"/><Class IRI="/Drug"/></ObjectPropertyDomain>
    <ObjectPropertyDomain><ObjectProperty IRI="/treats"/><Class IRI="/Drug"/></ObjectPropertyDomain>

    <ObjectPropertyRange><ObjectProperty IRI="/affects"/><Class IRI="/Anatomical_Part"/></ObjectPropertyRange>
    <ObjectPropertyRange><ObjectProperty IRI="/causes"/><Class IRI="/Symptom"/></ObjectPropertyRange>
    <ObjectPropertyRange><ObjectProperty IRI="/experiences"/><Class IRI="/Symptom"/></ObjectPropertyRange>
    <ObjectPropertyRange><ObjectProperty IRI="/has_anatomical_part"/><Class IRI="/Anatomical_Part"/></ObjectPropertyRange>
    <ObjectPropertyRange><ObjectProperty IRI="/has_symptom"/><Class IRI="/Symptom"/></ObjectPropertyRange>
    <ObjectPropertyRange><ObjectProperty IRI="/indicates"/><Class IRI="/Disease"/></ObjectPropertyRange>
    <ObjectPropertyRange><ObjectProperty IRI="/is_treated_by"/><Class IRI="/Drug"/></ObjectPropertyRange>
    <ObjectPropertyRange><ObjectProperty IRI="/located_in"/><Class IRI="/Anatomical_Part"/></ObjectPropertyRange>
    <ObjectPropertyRange><ObjectProperty IRI="/side_effect_of"/><Class IRI="/Drug"/></ObjectPropertyRange>
    <ObjectPropertyRange><ObjectProperty IRI="/targets"/><Class IRI="/Anatomical_Part"/></ObjectPropertyRange>
    <ObjectPropertyRange><ObjectProperty IRI="/treats"/><Class IRI="/Disease"/></ObjectPropertyRange>

    <DataPropertyDomain><DataProperty IRI="/name"/><Class IRI="/Person"/></DataPropertyDomain>
    <DataPropertyDomain><DataProperty IRI="/age"/><Class IRI="/Person"/></DataPropertyDomain>
    <DataPropertyDomain><DataProperty IRI="/dosage"/><Class IRI="/Drug"/></DataPropertyDomain>
    <DataPropertyDomain><DataProperty IRI="/active_ingredient"/><Class IRI="/Drug"/></DataPropertyDomain>
    <DataPropertyDomain><DataProperty IRI="/severity"/><Class IRI="/Disease"/></DataPropertyDomain>

    <DataPropertyRange><DataProperty IRI="/name"/><Datatype abbreviatedIRI="xsd:string"/></DataPropertyRange>
    <DataPropertyRange><DataProperty IRI="/age"/><Datatype abbreviatedIRI="xsd:integer"/></DataPropertyRange>
    <DataPropertyRange><DataProperty IRI="/dosage"/><Datatype abbreviatedIRI="xsd:string"/></DataPropertyRange>
    <DataPropertyRange><DataProperty IRI="/active_ingredient"/><Datatype abbreviatedIRI="xsd:string"/></DataPropertyRange>
    <DataPropertyRange><DataProperty IRI="/severity"/><Datatype abbreviatedIRI="xsd:string"/></DataPropertyRange>
</Ontology>
